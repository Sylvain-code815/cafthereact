<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Si le fichier ou dossier existe vraiment, le servir directement
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d

  # Sinon, tout rediriger vers index.html (React Router gère le routing)
  RewriteRule ^ index.html [QSA,L]
</IfModule>
